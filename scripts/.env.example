# R2 S3-compatible API credentials for uploading large model files.
# Generate these at: Cloudflare dashboard → R2 → Manage R2 API Tokens →
# Create API Token → "Admin Read & Write" → Apply to "local-models" bucket.
#
# Copy this file to scripts/.env and fill in the values, then run:
#   node scripts/upload-big-files.mjs

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
